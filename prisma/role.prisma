model Role {
    id    String  @id @default(uuid()) @db.Char(36)
    name  String  @unique @db.VarChar(100)
    title String? @db.VarChar(255)
    users User[]

    createdAt DateTime  @default(now())
    updatedAt DateTime  @default(now()) @updatedAt
    deletedAt DateTime?

    @@index([createdAt])
    @@index([updatedAt])
    @@index([deletedAt])
    @@schema("portfolio")
}
